{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-mcpserver",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/MsDynamics365MCP.MCPServer/MsDynamics365MCP.MCPServer.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "build-crmapi",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/MSDynamicsCRM.API/MSDynamicsCRM.API.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "build-mcpclient",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/MsDynamics365MCP.MCPClient/MsDynamics365MCP.MCPClient.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "build-all",
      "dependsOn": ["build-mcpserver", "build-crmapi", "build-mcpclient"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
